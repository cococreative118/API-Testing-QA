<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API-Testing-QA Suite" verbose="1">
    <!-- Register the Allure TestNG listener so test results are written to allure-results/ -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="API Tests">
        <classes>
            <class name="tests.GetUsersTest"/>
            <class name="tests.CreateUserTest"/>
            <class name="tests.PojoTest"/>
            <class name="tests.UserLifecycleTest"/>
            <class name="tests.TokenAuthTest"/>
            <class name="tests.DataDrivenTest"/>
        </classes>
    </test>
</suite>
